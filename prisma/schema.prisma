generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUM
// ============================================================

enum Role {
  ADMIN
  MITRA
  USER
}

enum StatusKetersediaan {
  TERSEDIA
  DISEWA
  PERAWATAN
}

enum StatusPemesanan {
  MENUNGGU
  DIKONFIRMASI
  AKTIF
  SELESAI
  DIBATALKAN
}

enum JenisTransaksi {
  TOPUP
  PEMBAYARAN
  REFUND
}

// ============================================================
// AUTH.JS REQUIRED MODELS
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// DOMAIN MODELS
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String? // hashed, null jika OAuth
  role          Role      @default(USER)
  noHp          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Auth.js relations
  accounts Account[]
  sessions Session[]

  // Domain relations
  mitra      Mitra?
  dompet     Dompet?
  pemesanan  Pemesanan[]

  @@map("users")
}

model Mitra {
  id        String   @id @default(cuid())
  userId    String   @unique
  namaMitra String
  noHp      String?
  alamat    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  armada  Armada[]
  dompet  Dompet?

  @@map("mitra")
}

model Armada {
  id                String             @id @default(cuid())
  mitraId           String
  namaKendaraan     String
  merek             String
  model             String
  tahun             Int
  nomorPlat         String             @unique
  statusKetersediaan StatusKetersediaan @default(TERSEDIA)
  hargaPerHari      Decimal            @db.Decimal(12, 2)
  foto              String?
  deskripsi         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  mitra     Mitra       @relation(fields: [mitraId], references: [id], onDelete: Cascade)
  pemesanan Pemesanan[]

  @@map("armada")
}

model Dompet {
  id       String  @id @default(cuid())
  userId   String? @unique
  mitraId  String? @unique
  saldo    Decimal @default(0) @db.Decimal(14, 2)

  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  mitra Mitra? @relation(fields: [mitraId], references: [id], onDelete: Cascade)

  transaksi TransaksiSaldo[]

  @@map("dompet")
}

model Pemesanan {
  id              String          @id @default(cuid())
  userId          String
  armadaId        String
  tanggalSewa     DateTime
  tanggalSelesai  DateTime
  totalHarga      Decimal         @db.Decimal(14, 2)
  statusPemesanan StatusPemesanan @default(MENUNGGU)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  armada Armada @relation(fields: [armadaId], references: [id], onDelete: Cascade)

  @@map("pemesanan")
}

model TransaksiSaldo {
  id              String         @id @default(cuid())
  dompetId        String
  jenis           JenisTransaksi
  jumlah          Decimal        @db.Decimal(14, 2)
  keterangan      String?
  tanggalTransaksi DateTime      @default(now())

  dompet Dompet @relation(fields: [dompetId], references: [id], onDelete: Cascade)

  @@map("transaksi_saldo")
}